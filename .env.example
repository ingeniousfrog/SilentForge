# SilentForge environment variables (optional)
# Copy to .env and adjust for local CLI / Workbench server usage.
# AI priority: local Codex (codex login) -> OpenAI API -> deterministic local rules.

# GitHub API (optional; raises rate limits)
# GITHUB_TOKEN=ghp_...

# --- Codex (preferred AI backend for `reposite init --ai`) ---
# Run `codex login` once; Codex CLI must be on PATH or set CODEX_PATH.
# CODEX_PATH=/opt/homebrew/bin/codex
# CODEX_MODEL=gpt-5.5

# --- OpenAI fallback (when Codex is unavailable or fails) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.5
# OPENAI_BASE_URL=http://127.0.0.1:8787/v1

# AI planning timeout in milliseconds (Codex default 60000; OpenAI API default 15000)
# SILENTFORGE_AI_TIMEOUT_MS=60000
